# SentimentPulse configuration — copy to .env and adjust.

# Database. Defaults to local SQLite; set a postgresql+asyncpg:// URL for Postgres.
# DATABASE_URL=sqlite+aiosqlite:///./sentimentpulse.db

# Reddit API (optional). Leave blank to run on the bundled seed dataset.
# Create a "script" app at https://www.reddit.com/prefs/apps to get these.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=sentimentpulse/2.0 (civic sentiment demo)

# App
DEBUG=true
INGESTION_INTERVAL_MINUTES=15
POSTS_PER_KEYWORD=25

# Concurrency / resilience for the ingestion fan-out
MAX_CONCURRENT_REQUESTS=5
REQUEST_MAX_RETRIES=3

# Optional token to enable the manual /api/trigger/* endpoints.
# When unset, those endpoints are disabled.
ADMIN_TOKEN=
